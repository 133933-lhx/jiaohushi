# ==================== Python 通用忽略 ====================
# 字节码文件
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境（绝对不能提交！）
venv/
env/
.venv/
ENV/

# 环境变量文件（绝对不能提交！包含你的API密钥）
.env
.env.local
.env.*.local

# 项目生成的历史文件
.input_history
chat_history.json

# 测试和覆盖率文件
.coverage
.pytest_cache/
htmlcov/

# IDE和编辑器文件
.idea/
.vscode/
*.iml
.DS_Store

# 打包和构建文件
dist/
build/
*.egg-info/
wheels/
